{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/mine",
      "destination": "https://nara-lockboard.pages.dev/"
    },
    {
      "source": "/mine/:path*",
      "destination": "https://nara-lockboard.pages.dev/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://nara-lockboard.pages.dev/api/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "https://nara-lockboard.pages.dev/assets/:path*"
    }
  ]
}
